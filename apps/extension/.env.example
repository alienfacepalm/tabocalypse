# Optional outbound links (new tab footer as text buttons). No backend required.
# Either set the three URLs below, or set WXT_TABOCALYPSE_SUPPORT_LINKS to a JSON array (see README).
WXT_TABOCALYPSE_SUPPORT_LINKS=
WXT_TABOCALYPSE_DONATE_URL=
WXT_TABOCALYPSE_FEATURE_URL=
WXT_TABOCALYPSE_GITHUB_URL=

# Required before Firefox AMO submit (unique reverse-domain add-on ID).
# Example: tabocalypse@alienfacepalm.com
WXT_TABOCALYPSE_FIREFOX_GECKO_ID=

# Optional HTTPS JSON for built-in humor pack line refresh (schema version 1; see humor-content-cache.ts).
WXT_TABOCALYPSE_BUILTIN_HUMOR_PACKS_URL=

# In-settings feedback form (Settings > Feedback & Feature Requests) — SMTP.js secure token + verified sender.
# Generate the token at https://smtpjs.com/ (Encrypt your SMTP credentials) using your Elastic Email / SMTP relay.
# Recipient defaults to jagon@alienfacepalm when WXT_TABOCALYPSE_FEEDBACK_TO is unset.
WXT_TABOCALYPSE_FEEDBACK_SMTP_SECURE_TOKEN=
WXT_TABOCALYPSE_FEEDBACK_FROM=
WXT_TABOCALYPSE_FEEDBACK_TO=
