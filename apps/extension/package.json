{
  "name": "extension",
  "version": "0.1.78",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build && tsx scripts/rename-chrome-mv3-to-chrome-edge-mv3.ts && wxt build -b safari --mv3 && wxt build -b firefox",
    "build:firefox": "wxt build -b firefox",
    "build:safari": "wxt build -b safari --mv3",
    "zip": "wxt zip",
    "postinstall": "wxt prepare",
    "scrape:unsuck-classics": "tsx scripts/scrape-unsuck-classics.ts",
    "icons:transparent-public": "tsx scripts/generate-transparent-public-icons.ts"
  },
  "dependencies": {
    "@fontsource/audiowide": "^5.2.7",
    "@tabocalypse/plugin-sdk": "workspace:*",
    "fflate": "^0.8.2",
    "lucide-react": "^1.14.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/webextension-polyfill": "^0.12.5",
    "@wxt-dev/auto-icons": "^1.1.1",
    "@wxt-dev/module-react": "^1.1.3",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.13",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "wxt": "^0.19.29"
  }
}
