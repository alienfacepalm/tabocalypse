{
  "name": "tabocalypse",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter extension dev",
    "dev:firefox": "pnpm --filter extension dev:firefox",
    "build": "pnpm --filter extension build",
    "build:firefox": "pnpm --filter extension build:firefox",
    "build:safari": "pnpm --filter extension build:safari",
    "zip": "pnpm --filter extension zip",
    "package:stores": "tsx scripts/package-store-deliverables.ts",
    "scripts:list": "tsx scripts/list-pnpm-scripts.ts",
    "format": "prettier --write \"**/*.{ts,tsx,mjs,cjs,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,mjs,cjs,json,md,css}\"",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:sdk": "tsc --noEmit -p packages/plugin-sdk/tsconfig.json",
    "check:extension": "pnpm --filter extension exec tsc --noEmit -p tsconfig.json",
    "check": "pnpm format:check && pnpm lint && pnpm test && pnpm check:sdk && pnpm check:extension",
    "scrape:unsuck-classics": "pnpm --filter extension scrape:unsuck-classics",
    "generate:settings-changelog": "pnpm --filter extension generate:settings-changelog",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,mjs,cjs}": [
      "eslint --max-warnings=0 --fix --no-warn-ignored",
      "prettier --write"
    ],
    "*.{json,md,css}": "prettier --write"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "eslint": "^9.19.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-unicorn": "^56.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.4.2",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.22.0",
    "vitest": "^3.0.5"
  }
}
